# Server Configuration
PORT=4000
NODE_ENV=development

# Database & Redis Connections
DATABASE_URL=postgresql://username:password@localhost:5432/schemaforge?schema=public
REDIS_URL=redis://localhost:6379

# Security Secrets (Must be at least 32 characters)
JWT_SECRET=super_secret_jwt_key_at_least_32_characters_long
JWT_REFRESH_SECRET=super_secret_jwt_refresh_key_at_least_32_characters_long
BCRYPT_ROUNDS=12

# Client Application URL
FRONTEND_URL=http://localhost:3000
