# ==========================================
# Server Configuration
# ==========================================
PORT=4000  # The port number on which the backend Express server will listen
NODE_ENV=development  # Current runtime environment: development | production | test
FRONTEND_URL=http://localhost:5173  # Client application URL allowed by CORS policies

# ==========================================
# Database & Redis Connections
# ==========================================
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/schemaforge?schema=public  # PostgreSQL connection string in postgresql://user:pass@host:port/dbname format
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=schemaforge
REDIS_URL=redis://:redispassword@localhost:6379  # Redis connection string in redis://:password@host:port format
REDIS_PASSWORD=redispassword  # Redis authorization password used in docker-compose.yml configuration

# ==========================================
# Security Settings & Secrets
# ==========================================
JWT_SECRET=super_secret_jwt_key_at_least_32_characters_long_for_access_tokens  # JWT signing secret for access tokens (must be 32+ random characters)
JWT_REFRESH_SECRET=another_super_secret_jwt_key_at_least_32_characters_long_for_refresh_tokens  # JWT signing secret for refresh tokens (must be 32+ random characters, different from JWT_SECRET)
BCRYPT_ROUNDS=12  # Work factor (cost factor) for bcrypt password hashing (default: 12, recommended range: 10-14)
